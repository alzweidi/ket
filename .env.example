# copy this file to .env in the repository root, or export the same keys in your shell

# IBM Quantum API token (also stored in ~/.ket/config)
IBM_QUANTUM_TOKEN=

# IBM Quantum instance (format: hub/group/project)
IBM_QUANTUM_INSTANCE=ibm-q/open/main

# IBM Quantum backend name
IBM_QUANTUM_BACKEND=ibm_brisbane
